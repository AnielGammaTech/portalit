{
	admin off
}

:8080 {
	root * /app/dist
	file_server

	# SPA fallback — serve index.html for all unknown routes
	try_files {path} /index.html

	# Never cache index.html — browser must always fetch the latest
	# (JS/CSS filenames contain hashes so they auto-bust)
	@html {
		path /
		path /index.html
	}
	header @html Cache-Control "no-cache, no-store, must-revalidate"

	# Cache hashed assets forever — filenames change on each build
	@assets {
		path /assets/*
	}
	header @assets Cache-Control "public, max-age=31536000, immutable"
}
